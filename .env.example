# ============================================================
#  AI Agent (analiza zahteva + procena rizika) - konfiguracija
#  Kopiraj ovaj fajl u ".env" i popuni vrednosti.
#  NIKAD ne commit-uj pravi .env u git (vidi .gitignore).
# ============================================================

# --- LLM provajder ---
# Podrzane vrednosti: openai | ollama
LLM_PROVIDER=ollama

# --- OpenAI (ako LLM_PROVIDER=openai) ---
OPENAI_API_KEY=sk-zameni-ovo-svojim-kljucem
# Primeri: gpt-4o-mini, gpt-4o, gpt-4.1-mini
OPENAI_MODEL=gpt-4o-mini

# --- Ollama (besplatno, lokalno - ako LLM_PROVIDER=ollama) ---
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# --- WooCommerce prodavnica (OPCIONO - samo za izvor "povuci prodavnicu") ---
# Ako ostavis prazno, agent i dalje radi sa tekstualnim/fajl ulazom.
WC_URL=http://localhost:8080
WC_CONSUMER_KEY=
WC_CONSUMER_SECRET=

# --- Ostalo ---
REQUEST_TIMEOUT=120
# Temperatura modela (0 = deterministicki, 1 = kreativnije)
LLM_TEMPERATURE=0.3
